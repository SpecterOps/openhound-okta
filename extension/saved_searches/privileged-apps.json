{
  "name": "Okta: Applications with Role Assignments",
  "description": "Applications that have roles assigned.",
  "query": "MATCH path = (:Okta_Organization)-[:Okta_Contains]->(:Okta_Application)-[:Okta_HasRoleAssignment]->(:Okta_RoleAssignment)-[:Okta_ScopedTo]->(:Okta)\nRETURN path\nLIMIT 1000"
}
